# Copy this file to .env and fill in your values before running docker-compose

# MySQL root password (used by the MySQL container)
MYSQL_ROOT_PASSWORD=rootpass

# Application DB credentials (used by all microservices)
DB_USER=gym_user
DB_PASS=gym_pass

# JWT secret — MUST be at least 32 characters, change in production!
JWT_SECRET=gym-super-secret-key-change-in-production-min-32-chars
